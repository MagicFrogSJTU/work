---
title: 2021年及之后升级的 3D 感知系统架构
---
flowchart TD
    classDef sensor fill:#DCEEFF,stroke:#2F6DB3,color:#16324F,stroke-width:1px;
    classDef process fill:#EAF7E8,stroke:#4D8B4D,color:#1F3A1F,stroke-width:1px;
    classDef ai fill:#FFF1D6,stroke:#C28B2C,color:#5B3D00,stroke-width:1px;
    classDef fusion fill:#F7E6F5,stroke:#9A5FA0,color:#4A214E,stroke-width:1px;
    classDef output fill:#FFE3E3,stroke:#BA5A5A,color:#5A1F1F,stroke-width:1px;

    subgraph S0[传感器输入]
        C1[多目 / 环视摄像头]
        R1[毫米波雷达]
        L1[激光雷达 可选]
        M1[定位 / IMU / 地图先验]
    end

    subgraph S1[统一时空对齐与特征构建]
        P1[时间同步 / 标定 / 自车坐标系对齐]
        P2[多相机图像编码]
        P3[雷达 / 激光点云特征编码]
    end

    subgraph S2[3D 空间表征主干]
        B1[View Transform / Lift-Splat / BEV特征生成]
        B2[多传感器 BEV Feature Fusion]
        B3[时序 BEV 融合主干]
    end

    subgraph S3[BEV 空间感知]
        D1[白名单动态目标检测<br/>车 人 骑行者等]
        D2[白名单静态目标检测<br/>锥桶 水马 路沿 杆体等]
        D3[BEV 车道 / 边界 / 路口语义]
        D4[BEV Tracking / Motion State]
    end

    subgraph S4[Occupancy 感知]
        O1[体素 / 网格 Occupancy 预测]
        O2[占据 / 空闲 / 未知空间估计]
        O3[通用障碍物发现<br/>不依赖白名单类别]
        O4[可通行空间与安全边界生成]
    end

    subgraph S5[融合决策接口]
        F1[目标级与栅格级结果对齐]
        F2[冲突消解 / 一致性约束]
        F3[统一环境模型输出]
    end

    subgraph S6[感知输出]
        Y1[BEV目标列表<br/>3D位置 速度 朝向 尺寸]
        Y2[Occupancy Grid / Voxel Map]
        Y3[通用障碍物 / 可通行区域]
        Y4[地图要素输出<br/>车道线 红绿灯 curb 地面标识 人行横道 停止线 车道 道路 路口 网格线 标牌 地面文字]
        Y5[供规划控制使用的统一世界模型]
    end

    C1 --> P1
    R1 --> P1
    L1 --> P1
    M1 --> P1
    P1 --> P2
    P1 --> P3
    P2 --> B1
    P3 --> B2
    B1 --> B2
    B2 --> B3
    B3 --> D1
    B3 --> D2
    B3 --> D3
    B3 --> O1
    D1 --> D4
    D2 --> D4
    D3 --> F1
    D4 --> F1
    O1 --> O2
    O2 --> O3
    O3 --> O4
    O4 --> F1
    F1 --> F2
    F2 --> F3
    F3 --> Y1
    F3 --> Y2
    F3 --> Y3
    F3 --> Y4
    F3 --> Y5

    class C1,R1,L1,M1 sensor;
    class P1,P2,P3 process;
    class B1,B2,B3,D1,D2,D3,D4,O1,O2,O3,O4 ai;
    class F1,F2,F3 fusion;
    class Y1,Y2,Y3,Y4,Y5 output;